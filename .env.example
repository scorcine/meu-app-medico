# Stripe — MedHub Pro (médico solo)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# URL pública (opcional; usada nos redirects do Checkout)
MEDHUB_SITE_URL=https://meu-app-medico.vercel.app

# Valores exibidos na página de planos (centavos BRL)
# Anual = mensal × 12 × 0,85 (15% de desconto) → 2990 × 12 × 0,85 = 30498
MEDHUB_PRICE_MONTHLY_CENTS=2990
MEDHUB_PRICE_ANNUAL_CENTS=30498
MEDHUB_PRICE_MONTHLY_DISPLAY=R$ 29,90
MEDHUB_PRICE_ANNUAL_DISPLAY=R$ 304,98

# Login na nuvem (Vercel KV + JWT)
MEDHUB_JWT_SECRET=change-me-long-random-string
KV_REST_API_URL=https://....upstash.io
KV_REST_API_TOKEN=...

# Versões legais (novo aceite quando mudar)
MEDHUB_TERMS_VERSION=2026-06-07-v1
MEDHUB_PRIVACY_VERSION=2026-06-07-v1

# Opcional: dias de trial
# MEDHUB_TRIAL_DAYS=7
